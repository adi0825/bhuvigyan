# ============================================================
# Bhuvigyan — Environment Configuration
# Copy to .env and fill in real values before `docker compose up`
# ============================================================

# -------- PostgreSQL --------
POSTGRES_DB=bhuvigyan
POSTGRES_USER=bhuvigyan
POSTGRES_PASSWORD=change_me_in_prod
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# -------- Cassandra --------
CASSANDRA_HOST=cassandra
CASSANDRA_PORT=9042
CASSANDRA_KEYSPACE=bhuvigyan_audit
CASSANDRA_DC=datacenter1

# -------- Redis --------
REDIS_HOST=redis
REDIS_PORT=6379

# -------- Kafka --------
KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# -------- Elasticsearch --------
ELASTIC_HOST=elasticsearch
ELASTIC_PORT=9200

# -------- MinIO (S3-compatible) --------
MINIO_ENDPOINT=http://minio:9000
MINIO_ROOT_USER=bhuvigyan
MINIO_ROOT_PASSWORD=change_me_in_prod
MINIO_REGION=ap-south-1
MINIO_BUCKET_SATELLITE=satellite-images
MINIO_BUCKET_NDVI=ndvi-reports
MINIO_BUCKET_PDF=pdf-evidence
MINIO_BUCKET_DOCS=farmer-documents
MINIO_BUCKET_AUDIT=audit-exports

# -------- JWT --------
# Generate via: openssl rand -base64 64
JWT_SECRET=REPLACE_WITH_64_BYTE_BASE64_SECRET_FROM_openssl_rand_base64_64
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=7
JWT_ISSUER=bhuvigyan.gov.in

# -------- Adapter Mode --------
# dev  = use DevAdapter with realistic synthesized data (safe for local)
# real = call real endpoints (requires credentials below)
STATE_API_MODE=dev
GEE_MODE=dev
WHATSAPP_MODE=dev
SMS_MODE=dev
PFMS_MODE=dev

# -------- Karnataka (Bhoomi / KGIS) --------
KGIS_BASE_URL=https://kgis.ksrsac.in/kgis
BHOOMI_BASE_URL=https://landrecords.karnataka.gov.in
KGIS_API_KEY=
BHOOMI_API_KEY=

# -------- Maharashtra (Mahabhumi) --------
MAHABHUMI_BASE_URL=https://abhilekh.mahabhumi.gov.in
MAHABHUMI_8A_BASE_URL=https://digitalsatbara.mahabhumi.gov.in
MAHABHUMI_API_KEY=

# -------- Telangana / Punjab / UP / Rajasthan --------
DHARANI_BASE_URL=https://dharani.telangana.gov.in
JAMABANDI_BASE_URL=https://jamabandi.punjab.gov.in
UP_BHULEKH_BASE_URL=https://upbhulekh.gov.in
APNAKHATA_BASE_URL=https://apnakhata.rajasthan.gov.in

# -------- Google Earth Engine --------
# Path inside the ml-service container to the service account JSON
GEE_SERVICE_ACCOUNT_KEY=/secrets/gee-sa.json
GEE_PROJECT_ID=

# -------- Gupshup WhatsApp Business --------
GUPSHUP_API_URL=https://api.gupshup.io/wa/api/v1
GUPSHUP_API_KEY=
GUPSHUP_SOURCE_NUMBER=

# -------- AWS SNS (SMS fallback) --------
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SNS_SENDER_ID=BHUVGY

# -------- PFMS (DBT payouts) --------
PFMS_BASE_URL=https://pfms.nic.in
PFMS_AGENCY_CODE=
PFMS_API_KEY=

# -------- ML service --------
ML_SERVICE_URL=http://ml-service:8000
ML_SERVICE_INTERNAL_KEY=change_me_shared_secret_between_spring_and_ml

# -------- Fraud thresholds (tunable without redeploy via admin API) --------
FRAUD_THRESHOLD_AUTO_APPROVE=30
FRAUD_THRESHOLD_REVIEW=60
FRAUD_THRESHOLD_CCE=80
